# Midtrans sandbox credentials (get from https://dashboard.sandbox.midtrans.com)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_MERCHANT_ID=Gxxxxxxxxx

# Midtrans API base. Default sandbox; override only for production.
MIDTRANS_API_BASE=https://api.sandbox.midtrans.com

# Midtrans Payment Link tunables.
# CUSTOMER_REQUIRED=true forces Midtrans to show the customer info form to
# the buyer. We intentionally do NOT send a customer_details object — the
# sandbox rejects empty/partial customer_details with a 400.
CUSTOMER_REQUIRED=true
# Comma-separated list. "other_qris" = generic QRIS (GoPay + ShopeePay QRIS).
ENABLED_PAYMENTS=other_qris
# Expiry: integer duration + plural unit ("minutes" | "hours" | "days").
EXPIRY_DURATION=15
EXPIRY_UNIT=minutes

# Meta Catalog (Facebook Commerce) — source of truth for product name/price.
# Get catalog ID from Commerce Manager → Catalog → Settings.
# META_ACCESS_TOKEN is a System User access token with catalog_management scope
# (Business Manager → Business Settings → System Users → Generate New Token).
META_CATALOG_ID=
META_ACCESS_TOKEN=
META_GRAPH_API_BASE=https://graph.facebook.com
META_GRAPH_VERSION=v25.0

# Runtime
PORT=8080
LOG_LEVEL=info
APP_ENV=development

# Rate limit: max requests per minute per IP on /checkout
RATE_LIMIT_PER_MIN=60
